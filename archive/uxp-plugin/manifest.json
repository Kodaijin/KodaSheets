{
  "manifestVersion": 5,
  "id": "com.kodasheets.imposition",
  "name": "Koda Sheets",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "kodaSheetsPanel",
      "label": {
        "default": "Koda Sheets"
      },
      "minimumSize": {
        "width": 300,
        "height": 400
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 400,
        "height": 720
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-light.png",
          "scale": [1],
          "theme": ["light"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-dark.png",
          "scale": [1],
          "theme": ["dark", "darkest"]
        },
        {
          "width": 46,
          "height": 46,
          "path": "icons/icon-light@2x.png",
          "scale": [2],
          "theme": ["light"]
        },
        {
          "width": 46,
          "height": 46,
          "path": "icons/icon-dark@2x.png",
          "scale": [2],
          "theme": ["dark", "darkest"]
        }
      ]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "clipboard": "read"
  }
}
